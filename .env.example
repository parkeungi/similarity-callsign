# ============================================
# 항공교통본부 유사호출부호 경고시스템 - 환경 설정
# ============================================
# 사용법: 이 파일을 복사하여 .env.local을 생성하고 실제 값을 입력하세요.
# 주의: .env.local은 .gitignore에 추가되어 커밋되지 않습니다.

# ============================================
# 📊 Database (PostgreSQL / Supabase 전용)
# ============================================
# 🐘 PostgreSQL / Supabase 연결 설정
# ============================================
#
# [1단계] Supabase 프로젝트 생성
#   → https://supabase.com → New Project
#
# [2단계] DATABASE_URL 가져오기 (서버 사이드 전용 ★필수)
#   → Supabase 대시보드 → Project Settings → Database
#   → "Connection string" 탭 → "URI" 복사
#   → 끝에 ?sslmode=require 추가 권장
#
#   형식: postgresql://postgres.[PROJECT_REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
#   (트랜잭션 풀러 포트 6543 권장, 세션 모드는 5432)
#
DATABASE_URL=postgresql://postgres.[PROJECT_REF]:[DB_PASSWORD]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres?sslmode=require

# ============================================
# 🔑 Supabase 클라이언트 키 (프론트엔드 + 서버)
# ============================================
#
# [3단계] API 키 가져오기
#   → Supabase 대시보드 → Project Settings → API
#
# NEXT_PUBLIC_SUPABASE_URL   : "Project URL" 항목 (공개 가능)
# NEXT_PUBLIC_SUPABASE_ANON_KEY : "anon public" 키 (공개 가능, RLS로 보호)
# SUPABASE_SERVICE_ROLE_KEY  : "service_role" 키 ★절대 클라이언트 노출 금지
#                              서버(API Route, Server Component)에서 RLS 우회 시 사용
#
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT_REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...anon_key...
SUPABASE_SERVICE_ROLE_KEY=eyJ...service_role_key...

# 서버 사이드 전용 (NEXT_PUBLIC_ 없는 버전 - API Route에서 사용)
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_ANON_KEY=eyJ...anon_key...

# ============================================
# 🔐 JWT Secret
# ============================================
# 현재 자체 JWT 인증 사용 시 필수
# 생성 방법: openssl rand -base64 32
#
# ★ Supabase Auth로 이전할 경우 이 값은 불필요해지며
#   Supabase JWT Secret(대시보드 → Settings → API → JWT Settings)으로 대체됩니다.
#
JWT_SECRET=your_jwt_secret_generated_with_openssl_rand_base64_32
# RefreshToken 전용 Secret (AccessToken과 분리 → 토큰 혼용 공격 차단)
# 생성: openssl rand -base64 32
REFRESH_TOKEN_SECRET=your_refresh_token_secret_generated_with_openssl_rand_base64_32

# ============================================
# 🌐 Application Configuration
# ============================================
NODE_ENV=production
NEXT_PUBLIC_APP_NAME=KATC 유사호출부호 경고시스템
# NEXT_PUBLIC_APP_URL=https://your-domain.com

# ============================================
# 📧 Email (SMTP) - 선택사항
# ============================================
# 현재: 관리자가 임시 비밀번호 수동 발급 방식 사용
# Supabase Auth 이전 시: Supabase 내장 Email Provider 사용 가능
#   → Supabase 대시보드 → Authentication → Email Templates
#   → 커스텀 SMTP: Settings → Authentication → SMTP Settings
#
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
# SMTP_FROM_EMAIL=your-email@gmail.com

# ============================================
# ⚙️ 마이그레이션 단계별 필요 정보 체크리스트
# ============================================
# [ 1단계 - 스키마 준비 ]
#   ✅ DATABASE_URL 설정
#   ✅ SUPABASE_SERVICE_ROLE_KEY 설정
#   → Supabase SQL Editor에서 PostgreSQL 스키마 실행
#
# [ 2단계 - API 연결 ]
#   ✅ NEXT_PUBLIC_SUPABASE_URL 설정
#   ✅ NEXT_PUBLIC_SUPABASE_ANON_KEY 설정
#   ✅ DB_PROVIDER=postgresql 설정
#
# [ 3단계 - Supabase Auth 이전 (선택) ]
#   ✅ Supabase Auth 활성화 (대시보드 → Authentication → Settings)
#   ✅ 이메일 도메인 화이트리스트 설정
#   ✅ 관리자 계정 초기 생성 (Supabase Auth 또는 직접 INSERT)
#   ✅ JWT_SECRET 불필요 (Supabase JWT로 대체)
#
# [ 4단계 - RLS 정책 설정 ]
#   ✅ 각 테이블별 Row Level Security 정책 작성
#   ✅ service_role 키로 관리자 API 동작 확인

# ============================================
# 🔒 보안 주의사항
# ============================================
# 1. SUPABASE_SERVICE_ROLE_KEY는 절대 NEXT_PUBLIC_ 접두사 사용 금지
# 2. .env.local은 절대 git 커밋 금지 (.gitignore 확인)
# 3. DATABASE_URL에 패스워드 포함 → 환경변수로만 관리
# 4. 프로덕션(Render/Vercel)은 대시보드 환경변수로 직접 설정
